sig <- abs(treat - ctrl) > 0.5
df <- data.frame(
  Control = ctrl,
  Treat   = treat,
  group   = ifelse(sig, "Significant", "NS")
)

# Basic usage (auto axis, wilcoxon test, pearson correlation)
PlotScatter3(df)

